rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 차량 사진: 인증된 사용자만 읽기/쓰기 가능
    match /vehicle-photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // 현장기록 사진: 인증된 사용자만 읽기/쓰기 가능
    match /field_visits/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // 그 외 경로: 기본 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
